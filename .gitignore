# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# Virtual environments
.venv/
venv/
env/

# Data files — only the top-level data/ store, NOT signals/data/ source code
/data/
*.parquet
*.db

# But DO track persisted sweep results under scripts/data/ so a fresh clone
# can inspect the raw per-window data without re-running the sweeps.
!scripts/data/*.parquet
!scripts/data/*.json
!scripts/data/*.xlsx

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Outputs — PNGs are generally ignored, but keep the small set of
# evaluation plots under scripts/data/plots/ so SKEPTIC_REVIEW results
# are visible to a fresh clone.
*.png
*.pdf
plots/
!scripts/data/plots/
!scripts/data/plots/*.png
